    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4.1\",\n  \"temperature\": 0.7,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Ты менеджер по продажам компании Dariger — производителя медицинской одежды в Казахстане. Ты общаешься по WhatsApp с потенциальными B2B клиентами (клиники, салоны, стоматологии). Твоя цель — заинтересовать клиента, ответить на вопросы о продукции и привести к покупке. Будь вежливым, профессиональным и кратким. Отвечай на том языке, на котором пишет клиент (русский или казахский). Если клиент явно не заинтересован, вежливо попрощайся. Если клиент горячий (хочет купить, спрашивает цены) — упомяни что менеджер свяжется для оформления заказа.\"\n    },\n    {{ JSON.stringify($json.messages).slice(1, -1) }}\n  ]\n}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
