    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Calculate date ranges for follow-ups\nconst now = new Date();\n\n// Follow-up 1: contacts sent 3 days ago\nconst fu1Date = new Date(now);\nfu1Date.setDate(fu1Date.getDate() - 3);\nconst fu1Start = fu1Date.toISOString().slice(0, 10) + 'T00:00:00';\nconst fu1End = fu1Date.toISOString().slice(0, 10) + 'T23:59:59';\n\n// Follow-up 2: contacts sent 7 days ago  \nconst fu2Date = new Date(now);\nfu2Date.setDate(fu2Date.getDate() - 7);\nconst fu2Start = fu2Date.toISOString().slice(0, 10) + 'T00:00:00';\nconst fu2End = fu2Date.toISOString().slice(0, 10) + 'T23:59:59';\n\n// Check if today is weekday (Mon-Fri)\nconst dayOfWeek = now.getDay();\nconst isWeekday = dayOfWeek >= 1 && dayOfWeek <= 5;\n\n// Check if within work hours (09:00-18:00 Almaty = UTC+5)\nconst almatyHour = (now.getUTCHours() + 5) % 24;\nconst isWorkHours = almatyHour >= 9 && almatyHour < 18;\n\nreturn {\n  fu1_start: fu1Start,\n  fu1_end: fu1End,\n  fu2_start: fu2Start,\n  fu2_end: fu2End,\n  is_weekday: isWeekday,\n  is_work_hours: isWorkHours,\n  should_run: isWeekday && isWorkHours\n};"
      },
