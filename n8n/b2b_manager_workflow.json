    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const response = $json;\nconst aiReply = response.choices?.[0]?.message?.content || 'Извините, попробуйте позже.';\nconst prevData = $('Prepare AI Context').first().json;\n\n// Detect hot lead signals\nconst hotKeywords = ['цена', 'прайс', 'стоимость', 'заказ', 'купить', 'оптом', 'баға', 'тапсырыс'];\nconst isHotLead = hotKeywords.some(kw => \n  prevData.user_message.toLowerCase().includes(kw)\n);\n\n// Detect language\nconst kazChars = /[әғқңөұүһі]/i;\nconst detectedLang = kazChars.test(prevData.user_message) ? 'kz' : 'ru';\n\nreturn {\n  contact_id: prevData.contact_id,\n  phone: prevData.phone,\n  ai_reply: aiReply,\n  is_hot_lead: isHotLead,\n  language: detectedLang,\n  updated_messages: [\n    ...prevData.messages,\n    { role: 'assistant', content: aiReply }\n  ]\n};"
      },
