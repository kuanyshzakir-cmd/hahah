    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const conv = $('Get Conversation').first().json[0] || {};\nconst incoming = $('Extract WA Data').first().json;\n\n// Get AI context from conversation\nconst aiContext = conv.ai_context || {};\nconst history = aiContext.messages || [];\nconst language = conv.language || 'ru';\n\n// Add new message to history\nhistory.push({\n  role: 'user',\n  content: incoming.body\n});\n\n// Keep only last 20 messages for context\nconst trimmedHistory = history.slice(-20);\n\nreturn {\n  contact_id: $('Save to Supabase').first().json.contact_id,\n  phone: incoming.from,\n  language: language,\n  messages: trimmedHistory,\n  user_message: incoming.body\n};"
      },
