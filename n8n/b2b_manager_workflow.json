    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract WhatsApp message from Meta webhook payload\nconst body = $json.body || $json;\n\n// Handle verification challenge (GET)\nif ($json.query && $json.query['hub.verify_token']) {\n  return { challenge: $json.query['hub.challenge'] };\n}\n\n// Extract message data\nconst entry = body.entry?.[0];\nconst changes = entry?.changes?.[0];\nconst value = changes?.value;\n\nif (!value) return { skip: true };\n\n// Handle status updates separately\nif (value.statuses && value.statuses.length > 0) {\n  const status = value.statuses[0];\n  return {\n    type: 'status',\n    wa_message_id: status.id,\n    status: status.status, // sent, delivered, read, failed\n    timestamp: status.timestamp,\n    recipient_id: status.recipient_id,\n    errors: status.errors || null\n  };\n}\n\n// Handle incoming messages\nif (value.messages && value.messages.length > 0) {\n  const msg = value.messages[0];\n  const contact = value.contacts?.[0];\n  \n  return {\n    type: 'message',\n    wa_message_id: msg.id,\n    from: msg.from, // phone number\n    contact_name: contact?.profile?.name || '',\n    timestamp: msg.timestamp,\n    message_type: msg.type, // text, image, document, etc.\n    body: msg.text?.body || msg.caption || '',\n    media_id: msg.image?.id || msg.document?.id || msg.audio?.id || null\n  };\n}\n\nreturn { skip: true };"
      },
