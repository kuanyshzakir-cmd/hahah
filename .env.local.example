# ===========================================
# B2B Manager (Dariger) — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Supabase (existing project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2GIS Catalog API
TWOGIS_API_KEY=your-2gis-api-key          # Get from platform.2gis.ru

# n8n Workflow: Dariger B2B Manager (ID: 8vGgyI6xgLzlPy67)
# Webhook paths defined in workflow:
#   - POST /webhook/whatsapp-incoming  → WhatsApp incoming messages
#   - POST /webhook/campaign-send      → Trigger campaign sending
#   - POST /webhook/whatsapp-status    → WhatsApp delivery status updates
#   - Schedule: daily 10:00 UTC        → Follow-up engine (day 3 & 7)
N8N_WEBHOOK_BASE_URL=https://zakirkuanysh.app.n8n.cloud/webhook
N8N_CAMPAIGN_WEBHOOK_PATH=campaign-send

# n8n Environment Variables (set in n8n Cloud Settings → Environment Variables):
#   SUPABASE_URL=https://your-project.supabase.co
#   WA_PHONE_NUMBER_ID=your-wa-phone-number-id
#   TG_BOT_TOKEN=your-telegram-bot-token
